{
  "name": "web-watcher",
  "version": "1.0.0",
  "description": "Surveille le web et alerte quand une information/annonce est publiée (sources connues + recherche web + juge LLM)",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "local": "node --env-file=.env src/index.js",
    "test:notify": "node --env-file=.env src/index.js --test-notify"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "nodemailer": "^6.9.16"
  },
  "engines": {
    "node": ">=20"
  }
}
