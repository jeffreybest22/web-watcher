# --- LLM juge (obligatoire) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Seuil de confiance pour déclencher une alerte (0-1). Défaut 0.6
CONFIDENCE_THRESHOLD=0.6

# --- Recherche web (optionnel : sans clé = DuckDuckGo gratuit) ---
# Mets UNE des deux pour une recherche plus fiable :
BRAVE_API_KEY=
TAVILY_API_KEY=

# --- Telegram (optionnel) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WhatsApp via OpenWA Pi 5 (optionnel) ---
# POST {OPENWA_URL}/api/sessions/{OPENWA_SESSION}/messages/send-text
# OPENWA_SESSION = UUID de la session (GET /api/sessions), PAS son nom.
OPENWA_URL=https://wa.jbjproductionhaiti.com
OPENWA_API_KEY=
OPENWA_SESSION=
WA_TO=5094XXXXXXX@c.us

# --- Email via Resend (optionnel, prioritaire sur SMTP) ---
RESEND_API_KEY=

# --- Email SMTP (optionnel, fallback) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=info@jbjproductionhaiti.com
MAIL_TO=info@jbjproductionhaiti.com
